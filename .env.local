# Qdrant Local Development Environment Variables
# Copy this file to .env.local and customize as needed

# Qdrant API URL (localhost for local development)
QDRANT_URL=http://localhost:6333

# API Key for Qdrant authentication (development mode)
QDRANT_API_KEY=dev-secret-key

# Collection name for RAG
COLLECTION_NAME=wiki-embeddings

# Embedding model
EMBEDDING_MODEL=BAAI/bge-m3

# Retrieval parameters
RETRIEVE_K=3