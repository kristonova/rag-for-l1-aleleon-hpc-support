# ChromaDB Local Development Environment Variables
# Copy this file to .env.local and customize as needed

# ChromaDB API URL (localhost for local development)
CHROMADB_URL=http://localhost:8002

# API Key for ChromaDB authentication (development mode)
CHROMADB_API_KEY=dev-secret-key

# Collection name for RAG
COLLECTION_NAME=wiki-embeddings

# Embedding model
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Retrieval parameters
RETRIEVE_K=3